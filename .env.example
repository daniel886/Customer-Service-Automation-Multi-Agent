# ===== Application =====
APP_NAME=Customer-Service-Automation-Multi-Agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-string
LOG_LEVEL=INFO

# ===== LLM Provider =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ===== Database =====
DATABASE_URL=sqlite+aiosqlite:///./data/customer_service.db
CHROMA_PERSIST_DIR=./data/chroma
KNOWLEDGE_BASE_DIR=./knowledge_base

# ===== WeChat Work (企业微信) =====
WECHAT_WORK_CORP_ID=ww1234567890abcdef
WECHAT_WORK_AGENT_ID=1000002
WECHAT_WORK_SECRET=your-app-secret
WECHAT_WORK_TOKEN=your-callback-token
WECHAT_WORK_AES_KEY=your-43-char-base64-encoding-aes-key
WECHAT_WORK_CALLBACK_PATH=/integrations/wechat/callback

# ===== Email (Gmail / SMTP / IMAP) =====
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp        # smtp | gmail_api
EMAIL_USERNAME=service@example.com
EMAIL_PASSWORD=app-specific-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_TLS=true
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_POLL_INTERVAL_SECONDS=60

# ===== Scheduler =====
DAILY_REPORT_CRON=0 9 * * *
DAILY_REPORT_TIMEZONE=Asia/Shanghai
DAILY_REPORT_RECIPIENTS=admin@example.com

# ===== Multi-Tenancy =====
DEFAULT_TENANT_ID=default
MULTI_TENANT_ENABLED=true

# ===== Human Takeover =====
HUMAN_TAKEOVER_TIMEOUT_MINUTES=30
HUMAN_TAKEOVER_NOTIFY_WEBHOOK=

# ===== Admin Panel =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
